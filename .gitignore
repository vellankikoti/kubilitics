# ============================================================================
# Kubilitics Platform — .gitignore
# ============================================================================

# ── OS-generated files ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Windows resource files (generated by go-winres during CI) ──────────────
*.syso

# ── IDE and editors ─────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
*.iml

# ── Dependencies ────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Build outputs ───────────────────────────────────────────────────────────
/build
dist/
/out/
/.next/
.cache/
.vite/

# ── Environment files ──────────────────────────────────────────────────────
*.env
*.env.*
!.env.example
!.env.template

# ── Internal / Sensitive documents (NEVER commit) ──────────────────────────
# Strategy, investor decks, pricing, competitive analysis
docs/enterprise-plans/
docs/internal/
*-STRATEGY.md
*-UNICORN*.md
*ENHANCEMENT-PLAN*.md
Lightning-Talk*.md
TASKS.md
*READINESS_REPORT*.md
*GAP_ANALYSIS*.md
*COMPLETION_REPORT*.md

# Confidential design documents
DESIGN_SYSTEM.md
DESIGN_CRITIQUE.md
DESIGN_SYSTEM_*.md

# ── Credentials and secrets (NEVER commit) ─────────────────────────────────
*.pem
*.key
*.cert
*.p12
*.pfx
*token.json*
*credentials.json*
kubeconfig
*.kubeconfig
service-account*.json

# ── Go ──────────────────────────────────────────────────────────────────────
# Binaries
kubilitics-backend/cmd/server/kubilitics-server
**/kubilitics-server
**/server
!**/server.go
!**/server.ts
!**/server.tsx
kubilitics-ai/bin/kubilitics-ai
**/bin/kubilitics-ai
**/kubilitics-ai-server
kubilitics-ai/server
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# ── Rust / Tauri ────────────────────────────────────────────────────────────
**/target/
kubilitics-desktop/dist/
kubilitics-desktop/src-tauri/gen/
!kubilitics-desktop/src-tauri/gen/schemas/
kubilitics-desktop/**/binaries/
**/binaries/*.exe
**/binaries/kubilitics-*
**/binaries/kcli-*

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# ── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Database files ──────────────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
dump.rdb

# ── Archive and large binary files ──────────────────────────────────────────
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib
*.lockb

# ── Office/media files (don't belong in a code repo) ───────────────────────
*.pptx
*.docx
*.doc
*.xlsx

# ── Test artifacts ──────────────────────────────────────────────────────────
/coverage
playwright-report/
test-results/
*.lcov
.nyc_output/

# ── Kubernetes cache (generated by tests) ──────────────────────────────────
.kube/

# ── Scaffolding / platform artifacts ───────────────────────────────────────
.emergent/
.claude/
.gitconfig
memory/
project-docs/

# ── Markdown control ───────────────────────────────────────────────────────
# Ignore stray markdown files to prevent AI-generated artifacts from being
# committed. Explicitly allow known documentation locations.
*.md
!README.md
!CHANGELOG.md
!CONTRIBUTING.md
!SECURITY.md
!NOTICE
!docs/*.md
!docs/**/*.md
!deploy/**/*.md
!kubilitics-frontend/docs/*.md

# ── Misc temp/debug files ──────────────────────────────────────────────────
body.json
test-pod.yaml
latest-kubeconfig.yaml
Topology.tsx
.vercel
.chainlit
chainlit.md
.ipynb_checkpoints/
.ac
android-sdk/
next-env.d.ts
*.tsbuildinfo

# ── Legacy paths (kcli and website moved to own repos) ─────────────────────
kcli/
website/
kcli-sdk/
.buildcache/
kubilitics-backend/server
kubilitics-backend/server_new
.superpowers/
docs/superpowers/
kubilitics-backend/test_output.txt
.worktrees/
