# Kubilitics — Environment template (B3.2)
# Copy to .env and adjust. Do not commit .env.
# Port reference: docs/INTEGRATION_PORTS.md

# Backend (kubilitics-backend) — default 819 to avoid conflict with 8080/3000
KUBILITICS_PORT=819
KUBILITICS_DATABASE_PATH=./kubilitics.db
KUBILITICS_LOG_LEVEL=info
KUBILITICS_REQUEST_TIMEOUT_SEC=30
KUBILITICS_TOPOLOGY_TIMEOUT_SEC=30
KUBILITICS_SHUTDOWN_TIMEOUT_SEC=15

# Frontend (kubilitics-frontend) — backend API base URL (must match KUBILITICS_PORT)
VITE_API_URL=http://localhost:819

# Optional: config file (YAML) path; overrides env if present
# KUBILITICS_CONFIG=/etc/kubilitics/config.yaml
